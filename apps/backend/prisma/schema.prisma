  region_id    String
  assigned_at  DateTime @default(now())
  assigned_by  String?

  inspector Inspector     @relation(fields: [inspector_id], references: [id], onDelete: Cascade)
  region    ServiceRegion @relation(fields: [region_id], references: [id], onDelete: Cascade)

  @@id([inspector_id, region_id])
  @@index([region_id])
  @@map("inspector_regions")
}


model NotificationConsent {
  id                 String               @id @default(uuid())
  recipient          String               @db.VarChar(320)
  channel            NotificationChannel
  tenant_id          String
  notification_class NotificationClass    @default(OPERATIONAL)
  opted_out          Boolean              @default(false)
  opted_out_at       DateTime?
  change_source      ConsentChangeSource?
  changed_at         DateTime?
  changed_by_user_id String?
  reason             String?              @db.Text
  created_at         DateTime             @default(now())
  updated_at         DateTime             @updatedAt

  changedBy User? @relation("NotificationConsentChangedBy", fields: [changed_by_user_id], references: [id])

  @@unique([recipient, channel, tenant_id, notification_class])
  @@index([tenant_id])
  @@map("notification_consents")
}

model EmailAsset {
  id                   String           @id @default(uuid())
  tenant_id            String?
  placeholder_key      String           @db.VarChar(64)
  storage_key          String           @unique @db.Text
  public_url           String           @db.Text
  original_filename    String           @db.VarChar(255)
  content_type         String           @db.VarChar(50)
  size_bytes           Int
  width                Int?
  height               Int?
  status               EmailAssetStatus @default(PENDING)
  ever_sent            Boolean          @default(false)
  uploaded_by_user_id  String

  created_at DateTime @default(now())

  uploadedBy     User                   @relation("EmailAssetUploadedBy", fields: [uploaded_by_user_id], references: [id])
  image_bindings TemplateImageBinding[]

  @@unique([tenant_id, placeholder_key])
  @@index([tenant_id])
  @@index([status])
  @@map("email_assets")
}

model TemplateImageBinding {
  id              String  @id @default(uuid())
  template_id     String
  asset_id        String
  placeholder_key String  @db.VarChar(64)
  alt_text        String? @db.VarChar(255)
  width           Int?
  height          Int?

  created_at DateTime @default(now())

  template NotificationTemplate @relation(fields: [template_id], references: [id])
  asset    EmailAsset            @relation(fields: [asset_id], references: [id])

  @@unique([template_id, placeholder_key])
  @@index([asset_id])
  @@map("template_image_bindings")
}
