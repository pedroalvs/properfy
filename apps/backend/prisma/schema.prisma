  delivery_mode             ScheduleDeliveryMode @default(OWNER_ONLY)
  recipient_user_ids        Json                 @default("[]")
  skip_delivery_when_empty  Boolean              @default(false)
  consecutive_failure_count Int                  @default(0)
  status                    ScheduleStatus       @default(ACTIVE)
  deleted_at                DateTime?
  // Legacy flag kept for back-compat; new code must read `status`
  is_active                 Boolean              @default(true)
  last_run_at               DateTime?
  next_run_at               DateTime?
  created_by_user_id        String
  created_at                DateTime             @default(now())
  updated_at                DateTime             @updatedAt

  tenant    Tenant               @relation(fields: [tenant_id], references: [id])
  createdBy User                 @relation("scheduledReportCreatedBy", fields: [created_by_user_id], references: [id])
  reports   Report[]
  runs      ScheduledReportRun[]

  @@index([tenant_id])
  @@index([is_active, next_run_at])
  @@index([status, next_run_at])
  @@index([created_by_user_id])
  @@map("scheduled_reports")
}

// Feature 019: per-run ledger for scheduled report executions
model ScheduledReportRun {
  id                   String            @id @default(uuid())
  schedule_id          String
  report_id            String?
  status               ScheduleRunStatus
  scheduled_for        DateTime
  started_at           DateTime?
  completed_at         DateTime?
  error_message        String?
  recipient_count      Int?
  delivery_status_json Json?
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt

  schedule ScheduledReport @relation(fields: [schedule_id], references: [id], onDelete: Cascade)
  report   Report?         @relation(fields: [report_id], references: [id], onDelete: SetNull)

  @@unique([schedule_id, scheduled_for])
  @@index([schedule_id, created_at])
  @@index([report_id])
  @@index([status])
  @@map("scheduled_report_runs")
}

model NotificationConsent {
  id                 String               @id @default(uuid())
  recipient          String               @db.VarChar(320)
  channel            NotificationChannel
  tenant_id          String
  notification_class NotificationClass    @default(OPERATIONAL)
  opted_out          Boolean              @default(false)
  opted_out_at       DateTime?
  change_source      ConsentChangeSource?
  changed_at         DateTime?
  changed_by_user_id String?
  reason             String?              @db.Text
  created_at         DateTime             @default(now())
  updated_at         DateTime             @updatedAt

  changedBy User? @relation("NotificationConsentChangedBy", fields: [changed_by_user_id], references: [id])

  @@unique([recipient, channel, tenant_id, notification_class])
  @@index([tenant_id])
  @@map("notification_consents")
}

model EmailAsset {
  id                   String           @id @default(uuid())
  tenant_id            String?
  placeholder_key      String           @db.VarChar(64)
  storage_key          String           @unique @db.Text
  public_url           String           @db.Text
  original_filename    String           @db.VarChar(255)
  content_type         String           @db.VarChar(50)
  size_bytes           Int
  width                Int?
  height               Int?
  status               EmailAssetStatus @default(PENDING)
  ever_sent            Boolean          @default(false)
  uploaded_by_user_id  String

  created_at DateTime @default(now())

  uploadedBy     User                   @relation("EmailAssetUploadedBy", fields: [uploaded_by_user_id], references: [id])
  image_bindings TemplateImageBinding[]

  @@unique([tenant_id, placeholder_key])
  @@index([tenant_id])
  @@index([status])
  @@map("email_assets")
}

model TemplateImageBinding {
  id              String  @id @default(uuid())
  template_id     String
  asset_id        String
  placeholder_key String  @db.VarChar(64)
  alt_text        String? @db.VarChar(255)
  width           Int?
  height          Int?

  created_at DateTime @default(now())

  template NotificationTemplate @relation(fields: [template_id], references: [id])
  asset    EmailAsset            @relation(fields: [asset_id], references: [id])

  @@unique([template_id, placeholder_key])
  @@index([asset_id])
  @@map("template_image_bindings")
}
