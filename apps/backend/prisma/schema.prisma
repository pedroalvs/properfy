model AppointmentImport {
  id                 String   @id @default(uuid())
  tenant_id          String
  // Appointment-import redesign — the preview/commit split.  `status` gains
  // a PREVIEW value (still a plain VarChar, no enum migration needed) for
  // the window between a synchronous preview and a requested commit.
  // `branch_id` is set at preview time (selected by the operator) and is
  // what both preview and commit derive tenant scope from for AM/OP.
  // `preview_json` caches the full resolver output shown to the operator;
  // `results_json` is written incrementally per row by the commit worker so
  // a crash/retry mid-batch resumes rather than risking a duplicate
  // appointment (the resolver itself is always re-run fresh at commit —
  // `preview_json` is a display cache, never authoritative for commit).
  branch_id          String?
  status             String   @default("PENDING") @db.VarChar(20)
  file_key           String   @db.VarChar(500)
  original_filename  String   @db.VarChar(255)
  total_rows         Int      @default(0)
  success_count      Int      @default(0)
  error_count        Int      @default(0)
  errors_json        Json?
  preview_json       Json?
  results_json       Json?
  created_by_user_id String
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  tenant     Tenant  @relation(fields: [tenant_id], references: [id])
  branch     Branch? @relation(fields: [branch_id], references: [id])
  created_by User    @relation("importCreatedBy", fields: [created_by_user_id], references: [id])

  @@index([tenant_id])
  @@index([status])
  @@index([created_by_user_id])
  @@index([created_at])
  @@map("appointment_imports")
}

