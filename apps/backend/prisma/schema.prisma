// This is your Prisma schema file.
// Auth, tenant, branch, property, service type, inspector, appointment entities.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  AM
  OP
  CL_ADMIN
  CL_USER
  INSP
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
  PENDING_INVITE
}

enum TenantStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum PropertyType {
  APARTMENT
  HOUSE
  COMMERCIAL
  INDUSTRIAL
  RURAL
}

enum GeocodingStatus {
  PENDING
  SUCCESS
  FAILED
  MANUAL
}

enum ServiceTypeFlowType {
  ROUTINE
  INGOING
  OUTGOING
}

enum ServiceTypeStatus {
  ACTIVE
  INACTIVE
}

enum PayoutType {
  FIXED
  PERCENTAGE
}

enum PriceRuleStatus {
  ACTIVE
  INACTIVE
}

enum InspectorStatus {
  ACTIVE
  INACTIVE
}

enum AvailabilitySlotStatus {
  AVAILABLE
  BOOKED
  CANCELLED
}

enum AppointmentStatus {
  DRAFT
  AWAITING_INSPECTOR
  SCHEDULED
  DONE
  CANCELLED
  REJECTED
}

enum RentalTenantConfirmationStatus {
  PENDING
  CONFIRMED
  UNAVAILABLE
  NO_RESPONSE
}

enum CycleStatus {
  PENDING
  CONFIRMED
  UNAVAILABLE
  SUPERSEDED
}

enum CycleConfirmationSource {
  RENTAL_TENANT_PORTAL
  OPERATOR_FORCED
  RENTAL_TENANT_RESCHEDULE
}

enum CycleInvalidatedReason {
  DATE_CHANGED
  TIME_CHANGED
  APPOINTMENT_REOPENED
  RENTAL_TENANT_RESCHEDULE
}

enum RestrictionSource {
  RENTAL_TENANT_PORTAL
  OPERATOR
  IMPORT
}

enum ContactType {
  RENTAL_TENANT
  PROPERTY_MANAGER
  HOUSEKEEPER
  BROKER
  OTHER
}

enum ContactChannelType {
  EMAIL
  PHONE
}

enum AppointmentContactRole {
  RENTAL_TENANT
  RENTAL_TENANT_REPRESENTATIVE
  HOUSEKEEPER
  PROPERTY_MANAGER
  BROKER
  OTHER
}

enum ServiceGroupStatus {
  DRAFT
  PUBLISHED
  ACCEPTED
  CANCELLED
  REJECTED
}

enum PriorityMode {
  STANDARD
  PRIORITY_24H
}

enum AuditActorType {
  USER
  SYSTEM
  ANONYMOUS
}

model Tenant {
  id            String       @id @default(uuid())
  name          String       @db.VarChar(200)
  legal_name    String       @unique @db.VarChar(200)
  status        TenantStatus @default(PENDING)
  timezone      String       @default("Australia/Sydney") @db.VarChar(60)
  currency      String       @default("AUD") @db.Char(3)
  settings_json Json         @default("{}")
  // Human-friendly appointment-code prefix (e.g. "INS" -> "INS-0042"). Promoted out of
  // settings_json so uniqueness is DB-enforced. Nullable for legacy rows (unique index
  // ignores NULLs); always uppercased on write so the plain unique index is case-insensitive.
  appointment_code_prefix String? @unique @db.VarChar(4)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt
  deleted_at    DateTime?

  branches               Branch[]
  users                  User[]
  properties             Property[]
  price_rules            ServicePriceRule[]
  appointments           Appointment[]
  financial_entries      FinancialEntry[]
  notifications          Notification[]
  notification_templates NotificationTemplate[]
  reports                Report[]
  appointment_imports    AppointmentImport[]
  property_imports       PropertyImport[]
  service_regions        ServiceRegion[]
  contacts               Contact[]
  app_credentials        AppCredential[]

  @@index([status])
  @@map("tenants")
}

model Branch {
  id            String       @id @default(uuid())
  tenant_id     String
  name          String       @db.VarChar(200)
  address_json  Json?
  contact_email String?      @db.VarChar(254)
  status        BranchStatus @default(ACTIVE)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt
  deleted_at    DateTime?

  tenant                 Tenant                @relation(fields: [tenant_id], references: [id])
  users                  User[]
  properties             Property[]
  price_rules            ServicePriceRule[]
  appointments           Appointment[]
  appointment_imports    AppointmentImport[]
  app_credentials        AppCredential[]

  // Case-insensitive unique index on (tenant_id, lower(name)) managed via raw SQL migration
  @@index([tenant_id, name])
  @@index([tenant_id])
  @@index([tenant_id, status])
  @@map("branches")
}

model User {
  id                 String     @id @default(uuid())
  tenant_id          String?
  branch_id          String?
  role               UserRole
  name               String     @db.VarChar(200)
  email              String     @db.VarChar(254)
  phone              String?    @db.VarChar(20)
  status             UserStatus @default(ACTIVE)
  password_hash      String
  // Encrypted at rest: stores AES-256-GCM ciphertext of the TOTP secret
  // (set/read via TotpEncryptionService), never the plaintext secret.
  totp_secret        String?
  totp_enabled       Boolean    @default(false)
  failed_login_count Int        @default(0)
  locked_until       DateTime?
  last_login_at      DateTime?
  created_at         DateTime   @default(now())
  updated_at         DateTime   @updatedAt
  deleted_at         DateTime?

  sessions                  Session[]
  password_reset_tokens     PasswordResetToken[]
  password_history          PasswordHistory[]
  tenant                    Tenant?               @relation(fields: [tenant_id], references: [id])
  branch                    Branch?               @relation(fields: [branch_id], references: [id])
  inspector                 Inspector?
  created_appointments      Appointment[]         @relation("AppointmentCreatedBy")
  done_marked_appointments  Appointment[]         @relation("AppointmentDoneMarkedBy")
  done_checked_appointments Appointment[]         @relation("AppointmentDoneCheckedBy")
  created_service_groups    ServiceGroup[]        @relation("ServiceGroupCreatedBy")
  initiated_entries         FinancialEntry[]      @relation("EntryInitiator")
  approved_entries          FinancialEntry[]      @relation("EntryApprover")
  voided_entries            FinancialEntry[]      @relation("EntryVoider")
  generated_invoices        InspectorInvoice[]    @relation("InspectorInvoiceGeneratedBy")
  paid_invoices             InspectorInvoice[]    @relation("InspectorInvoicePaidBy")
  consent_changes           NotificationConsent[] @relation("NotificationConsentChangedBy")
  requested_reports         Report[]
  created_imports           AppointmentImport[]   @relation("importCreatedBy")
  created_property_imports  PropertyImport[]      @relation("propertyImportCreatedBy")
  created_service_regions   ServiceRegion[]       @relation("ServiceRegionCreatedBy")
  uploaded_email_assets      EmailAsset[]          @relation("EmailAssetUploadedBy")

  @@index([tenant_id])
  @@index([tenant_id, role])
  @@index([tenant_id, status])
  @@index([branch_id])
  @@index([email])
  @@map("users")
}

model Session {
  id                 String    @id @default(uuid())
  user_id            String
  refresh_token_hash String
  ip_address         String?   @db.VarChar(45)
  user_agent         String?   @db.VarChar(500)
  country_code       String?   @db.VarChar(2)
  device_fingerprint String?   @db.VarChar(64)
  expires_at         DateTime
  revoked_at         DateTime?
  created_at         DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([refresh_token_hash])
  @@index([expires_at])
  @@index([user_id, revoked_at])
  @@map("sessions")
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([token_hash])
  @@index([user_id])
  @@index([expires_at])
  @@map("password_reset_tokens")
}

model PasswordHistory {
  id            String   @id @default(uuid())
  user_id       String
  password_hash String
  created_at    DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([user_id, created_at])
  @@map("password_history")
}

model Property {
  id               String          @id @default(uuid())
  tenant_id        String
  branch_id        String?
  property_code    String          @db.VarChar(50)
  type             PropertyType
  street           String          @db.VarChar(300)
  address_line_2   String?         @db.VarChar(200)
  suburb           String          @db.VarChar(100)
  postcode         String          @db.VarChar(20)
  state            String          @db.VarChar(100)
  country          String          @default("AU") @db.VarChar(100)
  // Deterministic normalized-address key — trim + collapse-whitespace +
  // lowercase join of street|address_line_2(''-coalesced)|suburb|state|postcode.
  // ALWAYS recomputed by a BEFORE INSERT/UPDATE trigger (see migration
  // 20260701230009) from whatever address ends up in the row, so every
  // create/update site (including test fixtures and seed scripts that predate
  // this feature and don't know about it) gets a correct value without
  // having to pass one — the `@default("")` below only exists to keep Prisma's
  // generated Create input optional; the literal default is never what
  // actually lands in a committed row. The JS twin
  // (shared/domain/normalize-address.ts) is used by `findByNormalizedAddress`'s
  // query and the appointment-import resolver's intra-batch grouping — it
  // MUST stay normalization-identical to the trigger's SQL. Backs the
  // `properties_normalized_address_active_unique` partial unique index
  // (WHERE deleted_at IS NULL), the DB-level guarantee behind the "perfect
  // address match" property-reuse rule.
  normalized_address_key String    @default("") @db.VarChar(750)
  // lat/lng are the display/transport coordinate; `coordinates` (PostGIS, below)
  // is the spatial source used for ST_Intersects/ST_DWithin. Both are kept in
  // sync app-side by prisma-property.repository.ts (syncCoordinates).
  lat              Decimal?        @db.Decimal(10, 7)
  lng              Decimal?        @db.Decimal(10, 7)
  geocoding_status GeocodingStatus @default(PENDING)
  private_area_m2  Decimal?        @db.Decimal(10, 2)
  total_area_m2    Decimal?        @db.Decimal(10, 2)
  furnished        Boolean?
  linen_provided   Boolean?
  rent_amount      Decimal?        @db.Decimal(12, 2)
  notes            String?         @db.Text
  rules_json       Json            @default("{}")
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  deleted_at       DateTime?

  coordinates  Unsupported("GEOMETRY(Point, 4326)")?
  tenant       Tenant                                @relation(fields: [tenant_id], references: [id])
  branch       Branch?                               @relation(fields: [branch_id], references: [id])
  appointments Appointment[]

  @@unique([tenant_id, property_code])
  @@index([tenant_id])
  @@index([tenant_id, type])
  @@index([branch_id])
  // Partial unique index managed in migration SQL (WHERE deleted_at IS NULL):
  // - properties_normalized_address_active_unique ON (tenant_id, normalized_address_key)
  @@map("properties")
}

model ServiceType {
  id                           String              @id @default(uuid())
  code                         String              @unique @db.VarChar(50)
  name                         String              @db.VarChar(200)
  flow_type                    ServiceTypeFlowType
  requires_rental_tenant_confirmation Boolean             @default(true)
  status                       ServiceTypeStatus   @default(ACTIVE)
  created_at                   DateTime            @default(now())
  updated_at                   DateTime            @updatedAt

  price_rules    ServicePriceRule[]
  appointments   Appointment[]
  service_groups ServiceGroup[]

  // Uniqueness enforced case-insensitively via migration index lower(name).
  // Prisma does not support functional indexes in schema, so the constraint
  // lives only in the migration SQL and the application-layer findByName check.
  @@index([status])
  @@map("service_types")
}

model ServicePriceRule {
  id              String          @id @default(uuid())
  tenant_id       String
  currency        String          @db.VarChar(3)
  service_type_id String
  branch_id       String?
  price_amount    Decimal         @db.Decimal(12, 2)
  payout_type     PayoutType
  payout_value    Decimal         @db.Decimal(12, 2)
  bonus_rule_json Json?
  status          PriceRuleStatus @default(ACTIVE)
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  tenant       Tenant      @relation(fields: [tenant_id], references: [id])
  service_type ServiceType @relation(fields: [service_type_id], references: [id])
  branch       Branch?     @relation(fields: [branch_id], references: [id])

  @@unique([tenant_id, service_type_id, branch_id])
  @@index([tenant_id])
  @@index([service_type_id])
  @@index([branch_id])
  @@map("service_price_rules")
}

model Inspector {
  id                         String          @id @default(uuid())
  user_id                    String?         @unique
  name                       String          @db.VarChar(200)
  email                      String          @unique @db.VarChar(254)
  phone                      String?         @db.VarChar(20)
  status                     InspectorStatus @default(ACTIVE)
  payment_settings_json      Json            @default("{}")
  // Inspector Property Invoice: billing cycle used to compute closed periods.
  // Nullable; the application defaults to FORTNIGHTLY when unset (spec 032).
  billing_cycle              BillingPeriodType?
  service_types_json         Json            @default("[]")
  // Feedback Round item 1: blocked-clients deny-list (replaced the legacy allow-list)
  blocked_clients_json       Json            @default("[]")
  // Feedback Round item 6: profile extension fields
  full_name                  String?         @db.VarChar(300)
  address                    Json?
  abn                        String?         @db.VarChar(20)
  date_of_birth              DateTime?       @db.Date
  insurance_file_key         String?
  insurance_expires_at       DateTime?       @db.Date
  insurance_meta_json        Json?
  police_check_file_key      String?
  police_check_expires_at    DateTime?       @db.Date
  police_check_meta_json     Json?
  photo_storage_key          String?
  availability_template_json Json            @default("{}")
  created_at                 DateTime        @default(now())
  updated_at                 DateTime        @updatedAt
  deleted_at                 DateTime?

  user                    User?                       @relation(fields: [user_id], references: [id])
  availability_slots      InspectorAvailabilitySlot[]
  appointments            Appointment[]
  assigned_service_groups ServiceGroup[]
  executions              InspectionExecution[]
  financial_entries       FinancialEntry[]
  invoices                InspectorInvoice[]
  inspector_regions       InspectorRegion[]

  @@index([status])
  @@index([user_id])
  @@index([insurance_expires_at])
  @@index([police_check_expires_at])
  @@map("inspectors")
}

model InspectorAvailabilitySlot {
  id                   String                 @id @default(uuid())
  inspector_id         String
  date                 DateTime               @db.Date
  start_time           String                 @db.VarChar(5)
  end_time             String                 @db.VarChar(5)
  region_json          Json?
  capacity             Int                    @default(1)
  status               AvailabilitySlotStatus @default(AVAILABLE)
  is_operator_override Boolean                @default(false)
  created_at           DateTime               @default(now())
  updated_at           DateTime               @updatedAt

  inspector Inspector @relation(fields: [inspector_id], references: [id])

  @@index([inspector_id])
  @@index([inspector_id, date])
  @@index([inspector_id, status])
  @@map("inspector_availability_slots")
}

model Appointment {
  id                           String                   @id @default(uuid())
  appointment_number           Int                      @unique @default(autoincrement())
  tenant_id                    String
  branch_id                    String
  property_id                  String
  service_type_id              String
  inspector_id                 String?
  service_group_id             String?
  status                       AppointmentStatus        @default(DRAFT)
  scheduled_date               DateTime                 @db.Date
  time_slot_start              String                   @db.VarChar(5)
  time_slot_end                String                   @db.VarChar(5)
  key_required                 Boolean                  @default(false)
  meeting_location             String?                  @db.VarChar(500)
  key_location                 String?                  @db.VarChar(500)
  // Intentional denormalization: a flat copy of the active
  // AppointmentConfirmationCycle status, kept on the appointment so dashboards,
  // reports and the portal can read/index it without joining the cycle. Derived
  // — keep in sync via confirmation-cycle.service when the cycle changes.
  rental_tenant_confirmation_status   RentalTenantConfirmationStatus @default(PENDING)
  active_confirmation_cycle_id String?
  price_amount                 Decimal                  @db.Decimal(12, 2)
  payout_amount                Decimal                  @db.Decimal(12, 2)
  pricing_rule_snapshot_json   Json
  // Three distinct free-text fields — do not conflate:
  //   notes       = internal operational note (OP/AM)
  //   tenant_note = note from the inquilino via the tenant portal
  //   observation = operator observation, carries its own audit trail
  notes                        String?                  @db.Text
  rental_tenant_note                  String?                  @db.Text
  observation                  String?                  @db.Text
  custom_fields_json           Json?
  // `reason` is the free-text reason for a sensitive transition; the
  // *_reason_code columns are the structured code for cancel/reject.
  reason                       String?                  @db.Text
  cancellation_reason_code     String?                  @db.VarChar(50)
  rejection_reason_code        String?                  @db.VarChar(50)
  created_by_user_id           String
  done_marked_by_user_id       String?
  done_checked_by_user_id      String?
  done_checked_at              DateTime?
  created_at                   DateTime                 @default(now())
  updated_at                   DateTime                 @updatedAt
  deleted_at                   DateTime?

  tenant               Tenant        @relation(fields: [tenant_id], references: [id])
  branch               Branch        @relation(fields: [branch_id], references: [id])
  property             Property      @relation(fields: [property_id], references: [id])
  service_type         ServiceType   @relation(fields: [service_type_id], references: [id])
  inspector            Inspector?    @relation(fields: [inspector_id], references: [id])
  service_group        ServiceGroup? @relation(fields: [service_group_id], references: [id])
  created_by_user      User          @relation("AppointmentCreatedBy", fields: [created_by_user_id], references: [id])
  done_marked_by_user  User?         @relation("AppointmentDoneMarkedBy", fields: [done_marked_by_user_id], references: [id])
  done_checked_by_user User?         @relation("AppointmentDoneCheckedBy", fields: [done_checked_by_user_id], references: [id])

  active_confirmation_cycle AppointmentConfirmationCycle?  @relation("ActiveCycle", fields: [active_confirmation_cycle_id], references: [id], onDelete: SetNull)
  confirmation_cycles       AppointmentConfirmationCycle[]

  contacts          AppointmentContact[]
  app_credentials   AppointmentAppCredential[]
  restrictions      AppointmentRestriction[]
  portal_tokens     RentalTenantPortalToken[]
  portal_activities RentalTenantPortalActivity[]
  execution         InspectionExecution?
  inspection_assets InspectionAsset[]
  financial_entries FinancialEntry[]
  notifications     Notification[]

  @@index([tenant_id, status])
  @@index([tenant_id, branch_id])
  @@index([tenant_id, inspector_id])
  @@index([tenant_id, scheduled_date])
  @@index([tenant_id, service_type_id])
  @@index([service_group_id])
  @@map("appointments")
}

model AppointmentConfirmationCycle {
  id                  String                   @id @default(uuid())
  appointment_id      String
  cycle_number        Int
  scheduled_date      DateTime                 @db.Date
  time_slot           String?
  status              CycleStatus              @default(PENDING)
  confirmation_source CycleConfirmationSource?
  confirmed_at        DateTime?
  invalidated_at      DateTime?
  invalidated_reason  CycleInvalidatedReason?
  portal_token_id     String?                  @unique
  created_at          DateTime                 @default(now())

  appointment      Appointment         @relation(fields: [appointment_id], references: [id], onDelete: Cascade)
  portal_token     RentalTenantPortalToken?  @relation("CycleMintedToken", fields: [portal_token_id], references: [id], onDelete: SetNull)
  active_for       Appointment[]       @relation("ActiveCycle")
  tokens_for_cycle RentalTenantPortalToken[] @relation("TokenCycle")

  @@unique([appointment_id, cycle_number])
  @@index([appointment_id, status])
  @@map("appointment_confirmation_cycles")
}

model ServiceGroup {
  id                    String                     @id @default(uuid())
  // Human-friendly sequential code (cross-tenant global sequence). Pure numeric.
  group_number          Int                        @unique @default(autoincrement())
  service_type_id       String
  status                ServiceGroupStatus         @default(DRAFT)
  group_size            Int
  offered_count         Int                        @default(0)
  confirmed_count       Int                        @default(0)
  scheduled_date        DateTime                   @db.Date
  time_window           String                     @db.VarChar(11)
  region_name           String?                    @db.VarChar(255)
  description           String?                    @db.Text
  priority_mode         PriorityMode               @default(STANDARD)
  priority_expires_at   DateTime?
  assigned_inspector_id String?
  service_region_id     String?
  published_at          DateTime?
  assigned_at           DateTime?
  created_by_user_id    String
  created_at            DateTime                   @default(now())
  updated_at            DateTime                   @updatedAt

  service_type       ServiceType    @relation(fields: [service_type_id], references: [id])
  assigned_inspector Inspector?     @relation(fields: [assigned_inspector_id], references: [id])
  service_region     ServiceRegion? @relation(fields: [service_region_id], references: [id], onDelete: Restrict)
  created_by         User           @relation("ServiceGroupCreatedBy", fields: [created_by_user_id], references: [id])
  appointments       Appointment[]

  @@index([status])
  @@index([scheduled_date])
  @@index([assigned_inspector_id])
  @@index([service_region_id])
  @@map("service_groups")
}

model Contact {
  id                       String      @id @default(uuid())
  // 024 §FR-301 — `tenant_id` is nullable. Contact is a cross-tenant entity;
  // visibility for CL_ADMIN/CL_USER is derived via the operational junction
  // (`appointment_contacts → appointments.tenant_id`). Standalone contacts
  // (created by AM/OP without an appointment context) carry `tenant_id = null`.
  tenant_id                String?
  type                     ContactType
  display_name             String      @db.VarChar(200)
  company                  String?     @db.VarChar(200)
  primary_email            String?     @db.VarChar(254)
  primary_phone            String?     @db.VarChar(30)
  additional_channels_json Json        @default("[]")
  notes                    String?
  is_active                Boolean     @default(true)
  created_at               DateTime    @default(now())
  updated_at               DateTime    @updatedAt

  tenant               Tenant?              @relation(fields: [tenant_id], references: [id])
  appointment_contacts AppointmentContact[]

  // Global partial unique indexes managed in 024 migration SQL (WHERE is_active = true):
  // - contacts_email_active_unique
  // - contacts_phone_active_unique
  // The composite (tenant_id, *) indexes below remain as hints for the AM/OP
  // explicit-tenant filter path; the new EXISTS-via-appointment_contacts
  // visibility predicate uses different indexes (covered by the FK indexes
  // on appointment_contacts.contact_id and appointments.tenant_id).
  @@index([tenant_id, type])
  @@index([tenant_id, is_active])
  @@index([tenant_id, display_name])
  @@map("contacts")
}

model AppointmentContact {
  id              String                 @id @default(uuid())
  appointment_id  String
  contact_id      String?
  role            AppointmentContactRole @default(RENTAL_TENANT)
  is_primary      Boolean                @default(true)
  // Snapshot of the contact at link time — the authoritative contact data
  // (024 contract: replaced the legacy tenant_name/primary_*/secondary_* inline columns).
  snapshot_name   String                 @db.VarChar(200)
  snapshot_email  String?                @db.VarChar(254)
  snapshot_phone  String?                @db.VarChar(30)
  created_at      DateTime               @default(now())
  updated_at      DateTime               @updatedAt

  appointment Appointment @relation(fields: [appointment_id], references: [id], onDelete: Cascade)
  contact     Contact?    @relation(fields: [contact_id], references: [id])

  @@index([appointment_id])
  @@index([contact_id])
  @@map("appointment_contacts")
}

// Per-agency (tenant) registry of third-party app/account logins an inspector
// needs on site. Managed by AM/OP only. `password_encrypted` holds the
// base64(iv‖authTag‖ciphertext) produced by Aes256GcmService; the plaintext
// password is shown in the UI but never stored in clear.
model AppCredential {
  id                              String   @id @default(uuid())
  tenant_id                       String
  branch_id                       String?
  name                            String   @db.VarChar(200)
  username                        String   @db.VarChar(200)
  password_encrypted              String
  needs_auth_code                 Boolean  @default(false)
  auth_code_encrypted             String?
  app_url                         String?  @db.VarChar(1000)
  instructions_url                String?  @db.VarChar(1000)
  instructions_password_encrypted String?
  is_active                       Boolean  @default(true)
  created_at                      DateTime @default(now())
  updated_at                      DateTime @updatedAt

