  period_end              DateTime               @db.Date
  period_type             BillingPeriodType
  status                  InspectorInvoiceStatus
  total_amount            Decimal                @default(0) @db.Decimal(12, 2)
  currency                String                 @db.Char(3)
  line_items_snapshot     Json?
  file_key                String?
  generated_by_user_id    String?
  issued_at               DateTime?
  paid_at                 DateTime?
  paid_by_user_id         String?
  payment_reference       String?                @db.VarChar(255)
  notes                   String?
  drafted_by_inspector_id String?
  created_at              DateTime               @default(now())
  updated_at              DateTime               @updatedAt

  inspector   Inspector @relation(fields: [inspector_id], references: [id])
  generatedBy User?     @relation("InspectorInvoiceGeneratedBy", fields: [generated_by_user_id], references: [id])
  paidBy      User?     @relation("InspectorInvoicePaidBy", fields: [paid_by_user_id], references: [id])

  // Uniqueness on (inspector_id, period_start, period_end) is enforced by a SQL-managed PARTIAL
  // unique index over ACTIVE statuses only ("inspector_invoices_active_period_unique",
  // WHERE status IN ('PENDING_REVIEW','CLOSED','PAID')) so a VOID invoice can coexist with a fresh
  // request for the same period. Prisma cannot express partial unique indexes, so it lives in the
  // migration and is intentionally absent here (spec 032).
  @@index([inspector_id, status])
  @@index([period_start, period_end])
  // GIN index backing the agency/branch snapshot CONTENT filters (spec 032).
  @@index([line_items_snapshot(ops: JsonbPathOps)], type: Gin, map: "inspector_invoices_line_items_snapshot_gin")
  @@map("inspector_invoices")
}

