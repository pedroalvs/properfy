{
  "name": "@properfy/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:db": "vitest run --config vitest.integration-db.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:refresh-demo": "tsx prisma/refresh-demo-seed.ts",
    "qa:provision-users": "tsx prisma/provision-qa-users.ts",
    "storage:provision": "tsx --env-file .env prisma/provision-storage-buckets.ts",
    "generate:openapi": "NODE_ENV=test tsx src/scripts/generate-openapi.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1010.0",
    "@aws-sdk/s3-request-presigner": "^3.1010.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "8",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.0.1",
    "@prisma/client": "^5.22.0",
    "@properfy/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "csv-parse": "^6.2.0",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.1",
    "fastify-type-provider-zod": "^2.1.0",
    "handlebars": "^4.7.9",
    "jose": "^5.9.6",
    "otplib": "^12.0.1",
    "pg-boss": "^9.0.3",
    "pino": "^9.5.0",
    "file-type": "^19.6.0",
    "html-to-text": "^9.0.5",
    "image-size": "^1.1.1",
    "resend": "^6.9.4",
    "sanitize-html": "^2.15.0",
    "twilio": "^5.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/exceljs": "^1.3.2",
    "@types/html-to-text": "^9.0.4",
    "@types/sanitize-html": "^2.13.0",
    "@types/node": "^20.17.9",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^1.6.1",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "testcontainers": "^11.14.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0"
  }
}
