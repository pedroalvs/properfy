# Database (PgBouncer pooled — used by the app at runtime)
# Note: percent-encode special chars in password (@ → %40, # → %23)
DATABASE_URL="postgresql://user:pass@host:6543/postgres?pgbouncer=true"

# Direct connection — used by Prisma Migrate only (bypasses PgBouncer)
DIRECT_URL="postgresql://user:pass@host:5432/postgres"

# JWT (RS256 key pair — generate with: openssl genrsa -out private.pem 2048)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
JWT_KEY_ID="properfy-key-v1"
# JWT_PREVIOUS_PUBLIC_KEY=""     # Optional: for key rotation
# JWT_PREVIOUS_KEY_ID=""         # Optional: for key rotation
# JWT_PREVIOUS_KEY_EXPIRES_AT="" # Optional: ISO 8601 — when the previous key stops being accepted
JWT_ACCESS_TOKEN_TTL_MINUTES=60  # Access token TTL in minutes (default: 60)

# TOTP (2FA encryption — generate with: openssl rand -hex 32)
TOTP_ENCRYPTION_KEY=""

# Supabase Storage (S3-compatible — used by the app at runtime)
SUPABASE_S3_ENDPOINT="https://<project>.storage.supabase.co/storage/v1/s3"
SUPABASE_S3_ACCESS_KEY_ID=""
SUPABASE_S3_SECRET_ACCESS_KEY=""
SUPABASE_STORAGE_BUCKET="properfy-assets"
# SUPABASE_STORAGE_PUBLIC_URL=""  # Optional: CDN public URL override for asset downloads

# Email asset image hosting (Feature 030: raw-HTML email authoring)
# Public base URL for the email-assets Supabase Storage bucket.
# The service appends /{bucketName}/{storageKey} — do NOT include the bucket name here.
# Example: https://<project>.supabase.co/storage/v1/object/public
# Required together with SUPABASE_S3_ENDPOINT to enable the email image library.
EMAIL_ASSETS_PUBLIC_URL_BASE="https://<project>.supabase.co/storage/v1/object/public"

# App
NODE_ENV="development"
PORT=3000
LOG_LEVEL="debug"
CORS_ORIGIN="http://localhost:5173"
PUBLIC_BASE_URL="http://localhost:3000"  # Public-facing API base URL (used in notification links)

# Email — Resend (https://resend.com)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="notifications@properfy.com.au"
# RESEND_WEBHOOK_SECRET=""  # Optional: for Resend delivery-status webhook signature verification

# SMS — MobileMessage (https://mobilemessage.com.au)
MOBILE_MESSAGE_API_KEY=""
MOBILE_MESSAGE_PASSWORD=""
MOBILE_MESSAGE_SENDER_ID=""
MOBILE_MESSAGE_WEBHOOK_TOKEN=""  # Required in staging/production; the delivery webhook rejects all requests when unset

# Geocoding — Mapbox (https://account.mapbox.com → Access tokens)
# Called server-to-server: use a secret (sk.) token scoped to only the
# geocoding permissions it needs, with NO browser URL restriction (distinct
# from the frontend's VITE_MAPBOX_TOKEN). A URL-restricted token fails every
# call with 403, since Mapbox checks the Referer header, which server-side
# requests never send.
MAPBOX_ACCESS_TOKEN=""

# Notifications — unsubscribe link signing
# Generate with: openssl rand -hex 32
NOTIFICATION_UNSUBSCRIBE_SECRET="dev-unsubscribe-secret"  # MUST be overridden in staging/prod

# Job queue (pg-boss) — set to "true" for staging/prod
ENABLE_JOB_QUEUE="true"

# pg-boss direct (non-pooled) connection — advisory locks + LISTEN/NOTIFY need a
# direct connection (port 5432), incompatible with PgBouncer transaction mode.
# Falls back to DATABASE_URL when unset. IMPORTANT: PG_BOSS_URL and DATABASE_URL
# must point to the SAME database, or workers will dequeue jobs from one DB and
# look up entities in another — silently no-op-ing them.
PG_BOSS_URL="postgresql://user:pass@host:5432/postgres"

# pg-boss schema — per-environment queue isolation. When unset it is derived from
# NODE_ENV (development → pgboss_dev, staging → pgboss_staging, production → pgboss).
# dev and staging share one database; without distinct schemas a dev laptop steals
# staging's jobs. Override here only if you need a custom schema.
# PGBOSS_SCHEMA="pgboss_dev"

# Audit retention batch size (default: 1000)
# AUDIT_RETENTION_BATCH_SIZE=1000
