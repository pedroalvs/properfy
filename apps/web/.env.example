# API base URL
VITE_API_BASE_URL=http://localhost:3000

# Mapbox token for map views (MapContainer, appointment map, property map, service group map).
# Obtain from: https://account.mapbox.com → Access tokens → Create a new token (public scope).
# Required for /appointments/map, /properties/map and /service-groups/map pages.
# Without this token those pages will display an error instead of rendering the map.
VITE_MAPBOX_TOKEN=
