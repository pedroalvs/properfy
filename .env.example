# ============================================================
# Properfy Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DATABASE_URL="postgresql://user:pass@host:5432/properfy?schema=public"

# ------------------------------------------------------------
# JWT (RS256 key pair)
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then encode newlines: awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem
# ------------------------------------------------------------
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
JWT_KEY_ID="properfy-key-v1"

# For key rotation (optional — set when rotating)
# JWT_PREVIOUS_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
# JWT_PREVIOUS_KEY_ID="properfy-key-v0"

# ------------------------------------------------------------
# External Services
# ------------------------------------------------------------
RESEND_API_KEY=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
MAPBOX_ACCESS_TOKEN=""

# ------------------------------------------------------------
# Supabase Storage
# ------------------------------------------------------------
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="properfy-assets"

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
NODE_ENV="development"
PORT=3000
LOG_LEVEL="debug"
CORS_ORIGIN="http://localhost:5173"
